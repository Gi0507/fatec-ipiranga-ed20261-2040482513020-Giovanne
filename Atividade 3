/*
1.Um Tipo Abstrato de Dados (TAD) é um modelo que define um conjunto de dados e as operações que podem ser realizadas sobre eles, sem mostrar como esses dados são implementados internamente. 
Sua característica fundamental é a abstração, ou seja, ocultar os detalhes da implementação e permitir que o usuário utilize apenas as operações disponíveis.

2. As vantagens de usar TADs são: melhor organização do código, facilidade de manutenção, reutilização de código e maior segurança, pois os dados ficam protegidos e acessíveis apenas por meio das operações definidas.

*/
CREATE DATABASE IF NOT EXISTS biblioteca;
USE biblioteca;

//CATEGORIA LEITOR
 
CREATE TABLE CategoriaLeitor (
    id_categoria INT AUTO_INCREMENT PRIMARY KEY,
    nome_categoria VARCHAR(50) NOT NULL UNIQUE
);

//SUBCLASSES
CREATE TABLE Graduando (
    id_categoria INT PRIMARY KEY,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE PosGraduando (
    id_categoria INT PRIMARY KEY,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE Professor (
    id_categoria INT PRIMARY KEY,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE Externo (
    id_categoria INT PRIMARY KEY,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE Funcionario (
    id_categoria INT PRIMARY KEY,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//LEITOR

CREATE TABLE Leitor (
    id_leitor INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    identidade VARCHAR(20) NOT NULL UNIQUE,
    data_nascimento DATE,
    telefone VARCHAR(20),
    email VARCHAR(100),
    endereco VARCHAR(150),
    cidade VARCHAR(100),
    estado VARCHAR(50),
    id_categoria INT NOT NULL,
    FOREIGN KEY (id_categoria)
        REFERENCES CategoriaLeitor(id_categoria)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

//CATEGORIA OBRA 

CREATE TABLE CategoriaObra (
    id_categoria_obra INT AUTO_INCREMENT PRIMARY KEY,
    nome_categoria VARCHAR(50) NOT NULL UNIQUE
);

//SUBCLASSES
CREATE TABLE Livro (
    id_categoria_obra INT PRIMARY KEY,
    FOREIGN KEY (id_categoria_obra)
        REFERENCES CategoriaObra(id_categoria_obra)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE Revista (
    id_categoria_obra INT PRIMARY KEY,
    FOREIGN KEY (id_categoria_obra)
        REFERENCES CategoriaObra(id_categoria_obra)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE Tese (
    id_categoria_obra INT PRIMARY KEY,
    FOREIGN KEY (id_categoria_obra)
        REFERENCES CategoriaObra(id_categoria_obra)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//OBRA LITERÁRIA

CREATE TABLE ObraLiteraria (
    codigo INT AUTO_INCREMENT PRIMARY KEY,
    isbn VARCHAR(20),
    titulo VARCHAR(200) NOT NULL,
    data_publicacao DATE,
    numero_edicao INT,
    editora VARCHAR(100),
    numero_paginas INT,
    palavras_chaves VARCHAR(200),
    id_categoria_obra INT NOT NULL,
    FOREIGN KEY (id_categoria_obra)
        REFERENCES CategoriaObra(id_categoria_obra)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

//AUTOR 

CREATE TABLE Autor (
    id_autor INT AUTO_INCREMENT PRIMARY KEY,
    nome_autor VARCHAR(100) NOT NULL
);

//OBRA-AUTOR
CREATE TABLE ObraAutor (
    codigo_obra INT,
    id_autor INT,
    PRIMARY KEY (codigo_obra, id_autor),
    FOREIGN KEY (codigo_obra)
        REFERENCES ObraLiteraria(codigo)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (id_autor)
        REFERENCES Autor(id_autor)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//CÓPIA

CREATE TABLE Copia (
    codigo_copia INT AUTO_INCREMENT PRIMARY KEY,
    codigo_obra INT NOT NULL,
    FOREIGN KEY (codigo_obra)
        REFERENCES ObraLiteraria(codigo)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//RESERVA

CREATE TABLE Reserva (
    id_reserva INT AUTO_INCREMENT PRIMARY KEY,
    data_reserva DATE NOT NULL,
    data_prevista_retirada DATE,
    id_leitor INT NOT NULL,
    codigo_obra INT NOT NULL,
    FOREIGN KEY (id_leitor)
        REFERENCES Leitor(id_leitor)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (codigo_obra)
        REFERENCES ObraLiteraria(codigo)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//DEVOLUÇÃO

CREATE TABLE Devolucao (
    id_devolucao INT AUTO_INCREMENT PRIMARY KEY,
    data_devolucao DATE NOT NULL,
    codigo_copia INT NOT NULL,
    id_leitor INT NOT NULL,
    FOREIGN KEY (codigo_copia)
        REFERENCES Copia(codigo_copia)
        ON DELETE RESTRICT
        ON UPDATE CASCADE,
    FOREIGN KEY (id_leitor)
        REFERENCES Leitor(id_leitor)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

//MULTA

CREATE TABLE Multa (
    id_multa INT AUTO_INCREMENT PRIMARY KEY,
    taxa DECIMAL(10,2) NOT NULL,
    numero_dias INT NOT NULL,
    id_devolucao INT UNIQUE,
    FOREIGN KEY (id_devolucao)
        REFERENCES Devolucao(id_devolucao)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);
